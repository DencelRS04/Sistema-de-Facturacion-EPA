@model Sistema_de_Facturacion_EPA.Models.Proveedor

@{
    ViewData["Title"] = "Eliminar Proveedor";
}

<div class="page-panel">
    <h2 class="section-title">Eliminar Proveedor</h2>

    <div class="alert alert-danger">
        ¿Seguro que deseas eliminar este proveedor?
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" value="@Model.Nombre" readonly />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Teléfono</label>
                    <input class="form-control" value="@Model.Telefono" readonly />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Correo</label>
                    <input class="form-control" value="@Model.Correo" readonly />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Fecha Registro</label>
                    <input class="form-control" value="@Model.FechaRegistro.ToShortDateString()" readonly />
                </div>

                <div class="col-12">
                    <label class="form-label">Dirección</label>
                    <input class="form-control" value="@Model.Direccion" readonly />
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4 d-flex gap-2">
                <input type="hidden" asp-for="IdProveedor" />
                <button type="submit" class="btn btn-danger">Eliminar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>