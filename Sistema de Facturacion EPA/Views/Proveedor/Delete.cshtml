@model Sistema_de_Facturacion_EPA.Models.Proveedor

@{
    ViewData["Title"] = "Eliminar Proveedor";
}

<h2>Eliminar Proveedor</h2>

<div class="alert alert-danger">
    ¿Seguro que deseas eliminar este proveedor?
</div>

<div class="mb-3">
    <label class="form-label">ID</label>
    <input class="form-control" value="@Model.IdProveedor" readonly />
</div>

<div class="mb-3">
    <label class="form-label">Nombre</label>
    <input class="form-control" value="@Model.Nombre" readonly />
</div>

<div class="mb-3">
    <label class="form-label">Teléfono</label>
    <input class="form-control" value="@Model.Telefono" readonly />
</div>

<div class="mb-3">
    <label class="form-label">Correo</label>
    <input class="form-control" value="@Model.Correo" readonly />
</div>

<div class="mb-3">
    <label class="form-label">Dirección</label>
    <input class="form-control" value="@Model.Direccion" readonly />
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="IdProveedor" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>