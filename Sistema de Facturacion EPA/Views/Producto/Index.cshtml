@model IEnumerable<Sistema_de_Facturacion_EPA.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Productos</h2>
    <a asp-action="Create" class="btn btn-success">Nuevo Producto</a>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-success">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio Venta</th>
            <th>Impuesto</th>
            <th>Categoría</th>
            <th style="width: 180px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdProducto</td>
                <td>@item.Nombre</td>
                <td>@item.Descripcion</td>
                <td>₡ @item.PrecioVenta.ToString("N2")</td>
                <td>@item.Impuesto %</td>
                <td>@item.CategoriaProducto?.Nombre</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.IdProducto" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.IdProducto" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>