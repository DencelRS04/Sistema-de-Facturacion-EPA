@model Sistema_de_Facturacion_EPA.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<div class="page-panel">
    <h2 class="section-title">Eliminar Producto</h2>

    <div class="alert alert-danger">
        ¿Seguro que deseas eliminar este producto?
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" value="@Model.Nombre" readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Precio Venta</label>
                    <input class="form-control" value="@Model.PrecioVenta.ToString("N2")" readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Impuesto</label>
                    <input class="form-control" value="@Model.Impuesto" readonly />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Categoría</label>
                    <input class="form-control" value="@Model.CategoriaProducto?.Nombre" readonly />
                </div>

                <div class="col-12">
                    <label class="form-label">Descripción</label>
                    <textarea class="form-control" readonly>@Model.Descripcion</textarea>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4 d-flex gap-2">
                <input type="hidden" asp-for="IdProducto" />
                <button type="submit" class="btn btn-danger">Eliminar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>