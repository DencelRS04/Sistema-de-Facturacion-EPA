@model IEnumerable<Sistema_de_Facturacion_EPA.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="page-panel">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="section-title mb-1">Clientes</h2>
            <p class="text-muted mb-0">Consulta y administración de clientes.</p>
        </div>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-person-plus me-1"></i> Nuevo Cliente
        </a>
    </div>

    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre Completo</th>
                <th>Teléfono</th>
                <th>Correo</th>
                <th>Dirección</th>
                <th>Fecha Registro</th>
                <th style="width:180px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdCliente</td>
                    <td>@item.NombreCompleto</td>
                    <td>@item.Telefono</td>
                    <td>@item.Correo</td>
                    <td>@item.Direccion</td>
                    <td>@item.FechaRegistro.ToShortDateString()</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.IdCliente" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.IdCliente" class="btn btn-danger btn-sm">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>