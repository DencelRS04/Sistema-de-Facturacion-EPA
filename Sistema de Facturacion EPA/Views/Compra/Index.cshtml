@model IEnumerable<Sistema_de_Facturacion_EPA.Models.Compra>

@{
    ViewData["Title"] = "Compras";
}

<div class="page-panel">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="section-title mb-1">Compras</h2>
            <p class="text-muted mb-0">Registro de compras realizadas a proveedores.</p>
        </div>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-cart-plus me-1"></i> Nueva Compra
        </a>
    </div>

    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>ID Compra</th>
                <th>Proveedor</th>
                <th>Fecha</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdCompra</td>
                    <td>@item.Proveedor?.Nombre</td>
                    <td>@item.FechaCompra.ToShortDateString()</td>
                    <td>₡ @item.Total.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>
</div>