@model IEnumerable<Sistema_de_Facturacion_EPA.Models.Inventario>

@{
    ViewData["Title"] = "Inventario";
}

<div class="page-panel">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="section-title mb-1">Inventario</h2>
            <p class="text-muted mb-0">Consulta del stock actual y niveles mínimos.</p>
        </div>
    </div>

    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>ID Inventario</th>
                <th>Producto</th>
                <th>Categoría</th>
                <th>Stock</th>
                <th>Stock Mínimo</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdInventario</td>
                    <td>@item.Producto?.Nombre</td>
                    <td>@item.Producto?.CategoriaProducto?.Nombre</td>
                    <td>@item.Stock</td>
                    <td>@item.StockMinimo</td>
                    <td>
                        @if (item.Stock == 0)
                        {
                            <span class="badge bg-danger">Sin stock</span>
                        }
                        else if (item.Stock < item.StockMinimo)
                        {
                            <span class="badge bg-warning text-dark">Stock bajo</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Normal</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>