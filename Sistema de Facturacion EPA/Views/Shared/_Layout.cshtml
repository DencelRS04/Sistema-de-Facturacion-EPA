<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Facturacion EPA</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-icon">
                    <i class="bi bi-shop"></i>
                </div>
                <div>
                    <h4 class="mb-0">EPA</h4>
                    <small>Sistema de Facturación</small>
                </div>
            </div>

            <nav class="sidebar-menu">
                <a asp-controller="Home" asp-action="Index" class="menu-link">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Inicio</span>
                </a>

                <a asp-controller="CategoriaProducto" asp-action="Index" class="menu-link">
                    <i class="bi bi-tags-fill"></i>
                    <span>Categorías</span>
                </a>

                <a asp-controller="Proveedor" asp-action="Index" class="menu-link">
                    <i class="bi bi-truck"></i>
                    <span>Proveedores</span>
                </a>

                <a asp-controller="Cliente" asp-action="Index" class="menu-link">
                    <i class="bi bi-people-fill"></i>
                    <span>Clientes</span>
                </a>

                <a asp-controller="Producto" asp-action="Index" class="menu-link">
                    <i class="bi bi-box-seam"></i>
                    <span>Productos</span>
                </a>

                <a asp-controller="Inventario" asp-action="Index" class="menu-link">
                    <i class="bi bi-clipboard-data-fill"></i>
                    <span>Inventario</span>
                </a>

                <a asp-controller="Compra" asp-action="Index" class="menu-link">
                    <i class="bi bi-cart-plus-fill"></i>
                    <span>Compras</span>
                </a>

                <a asp-controller="Factura" asp-action="Index" class="menu-link">
                    <i class="bi bi-receipt-cutoff"></i>
                    <span>Facturación</span>
                </a>

                <a asp-controller="Reportes" asp-action="Index" class="menu-link">
                    <i class="bi bi-bar-chart-fill"></i>
                    <span>Reportes</span>
                </a>
            </nav>
        </aside>

        <div class="main-content">
            <header class="topbar">
                <div>
                    <h5 class="page-title mb-0">@ViewData["Title"]</h5>
                    <small class="text-muted">Sistema_de_Facturacio_EPA</small>
                </div>

                <div class="topbar-user">
                    <div class="user-avatar">
                        <i class="bi bi-person-circle"></i>
                    </div>
                </div>
            </header>

            <main class="content-wrapper">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>