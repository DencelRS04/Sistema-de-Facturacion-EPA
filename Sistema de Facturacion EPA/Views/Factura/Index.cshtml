@model IEnumerable<Sistema_de_Facturacion_EPA.Models.Factura>

@{
    ViewData["Title"] = "Facturación";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Facturación</h2>
    <a asp-action="Create" class="btn btn-success">Nueva Factura</a>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-success">
        <tr>
            <th>ID Factura</th>
            <th>Cliente</th>
            <th>Fecha</th>
            <th>Subtotal</th>
            <th>Impuesto</th>
            <th>Total</th>
            <th>Estado</th>
            <th style="width: 120px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdFactura</td>
                <td>@item.Cliente?.NombreCompleto</td>
                <td>@item.FechaFactura.ToShortDateString()</td>
                <td>₡ @item.Subtotal.ToString("N2")</td>
                <td>₡ @item.Impuesto.ToString("N2")</td>
                <td>₡ @item.Total.ToString("N2")</td>
                <td>@item.Estado</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.IdFactura" class="btn btn-primary btn-sm">Ver</a>
                </td>
            </tr>
        }
    </tbody>
</table>